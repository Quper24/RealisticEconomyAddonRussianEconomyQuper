SiiNunit
{

	bank_data : bank.data.storage
	{
		min_after_loan_repay:	-1000

		loan_offers[]: bank.data.loan1
		loan_offers[]: bank.data.loan2
		loan_offers[]: bank.data.loan3
		loan_offers[]: bank.data.loan4

		overdraft_duration:	28	# days
		overdraft_warn_day:	7	# starting on 3rd day

	}

	bank_loan_data: bank.data.loan1
	{
		amount: 10000
		interest_rate: 0.18	# 23 %
		duration: 12		# in weeks
	}

	bank_loan_data: bank.data.loan2
	{
		amount: 50000
		interest_rate: 0.20	# 18 %
		duration: 24		# in weeks
	}

	bank_loan_data: bank.data.loan3
	{
		amount: 100000
		interest_rate: 0.24	# 14 %
		duration: 36		# in weeks
	}

	bank_loan_data: bank.data.loan4
	{
		amount: 400000
		interest_rate: 0.28	# 10 %
		duration: 60		# in weeks
	}

}
